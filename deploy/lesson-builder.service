[Unit]
Description=X-active lesson builder
After=network.target

[Service]
User=deploy
Group=deploy
WorkingDirectory=/srv/deploy/projects/x-active-obuchenie/repo
Environment=PATH=/srv/deploy/projects/x-active-obuchenie/venv/bin:/usr/bin
ExecStart=/srv/deploy/projects/x-active-obuchenie/venv/bin/gunicorn --bind 127.0.0.1:8765 --workers 1 --threads 4 --timeout 600 lesson_builder.server:app
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
